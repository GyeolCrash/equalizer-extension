{
  "manifest_version": 3,
  "name": "Audio Manipulator: EQ, Compressor, Pitch Shifter",
  "version": "1.0.0",
  "description": "A Chrome extension for advanced audio manipulation with real-time visualization and user-friendly controls.",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage",
    "sidePanel",
    "identity"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://polar.sh*",
    "https://www.youtube.com/*",
    "https://open.spotify.com/*",
    "https://www.netflix.com/*",
    "https://soundcloud.com/*"
  ],
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Audio Manipulator"
  },
  "icons": {
    "16": "/icons/icon-16.png",
    "48": "/icons/icon-48.png",
    "128": "/icons/icon-128.png"
  },
  "key": "__EXTENSION_KEY__"
}