{
  "manifest_version": 3,
  "name": "Graph-based Audio Equalizer",
  "version": "1.0.0",
  "description": "동적 그래프 기반 이퀄라이저 - Web Audio API를 통한 자유로운 주파수 제어 및 실시간 시각화",
  "permissions": [
    "tabCapture",
    "activeTab",
    "offscreen",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Parametric Equalizer"
  },
  "icons": {
    "16": "/icons/icon-16.png",
    "48": "/icons/icon-48.png",
    "128": "/icons/icon-128.png"
  }
}