rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection rules
    // Rule 93: Access to the 'users' collection must be restricted to the document owner.
    match /users/{userId} {
      // Rule 60: Use the Google User ID (sub claim from ID token) as the Primary Document ID.
      // request.auth refers to the JWT token validated by Firebase.
      // Since the frontend uses Firebase Auth (or manual verification for Cloud Run), 
      // the document owner must be the authenticated user.
      allow read: if request.auth != null && request.auth.uid == userId;
      // always deny write
      allow write: if false;
    }
  }
}
